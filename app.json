{
  "expo": {
    "name": "Ophinia",
    "slug": "autograph-app-v2",
    "version": "1.0.0",
    "orientation": "default",
    "icon": "./assets/images/icon-square-ios.png",
    "scheme": "tapnsign",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "usesAppleSignIn": true,
      "infoPlist": {
        "NSCameraUsageDescription": "Allow this app to use your camera to capture autograph videos.",
        "NSMicrophoneUsageDescription": "Allow this app to record audio with autograph videos.",
        "NSPhotoLibraryAddUsageDescription": "Allow this app to save autograph videos to your library.",
        "ITSAppUsesNonExemptEncryption": false
      },
      "bundleIdentifier": "com.tapnsign.app",
      "appleTeamId": "84343HMCYD"
    },
    "android": {
      "permissions": [
        "CAMERA",
        "RECORD_AUDIO",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_VISUAL_USER_SELECTED",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.READ_MEDIA_AUDIO"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/icon-square-ios.png",
        "monochromeImage": "./assets/images/icon-square-ios.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.tapnsign.app"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/icon-square-ios.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/Ophinia_name_no tm_white.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Allow this app to use your camera",
          "microphonePermission": "Allow this app to record audio"
        }
      ],
      "expo-media-library",
      [
        "expo-notifications",
        {
          "iosDisplayInForeground": true
        }
      ],
      [
        "@stripe/stripe-react-native",
        {
          "merchantIdentifier": "merchant.com.tapnsign",
          "enableGooglePay": false
        }
      ],
      "./plugins/withModularHeaders",
      "expo-apple-authentication",
      "@react-native-community/datetimepicker",
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.529537228510-o2v5msi2p0khqbvb2qo7u4j5sg95ui7g"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": false
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "985dc536-2d58-499d-bab4-07b27d8f73a7"
      }
    },
    "owner": "aofer"
  }
}
